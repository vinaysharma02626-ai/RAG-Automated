# ============================================================
# RAG Automation - Backend Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- App ---
DEBUG=false
SECRET_KEY=change-me-in-production

# --- CORS (comma-separated origins) ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Storage ---
UPLOAD_DIR=./data/uploads
INDEX_DIR=./data/indexes
DATABASE_URL=sqlite+aiosqlite:///./data/rag.db

# --- Upload limits ---
MAX_UPLOAD_SIZE_MB=50
MAX_DOCS_PER_SESSION=20

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_CHUNKS_PER_DOC=1000

# --- Retrieval ---
TOP_K_RETRIEVAL=20
TOP_N_RERANK=5
VECTOR_WEIGHT=0.6
BM25_WEIGHT=0.4

# ============================================================
# LLM PROVIDER - Choose one of: groq, openrouter, ollama, huggingface
# ============================================================

# --- OPTION A: Groq (FREE tier, fast, recommended) ---
# Sign up at https://console.groq.com — no credit card needed
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
LLM_API_KEY=your_groq_api_key_here

# --- OPTION B: OpenRouter (many free models) ---
# LLM_PROVIDER=openrouter
# LLM_MODEL=mistralai/mistral-7b-instruct:free
# LLM_API_KEY=your_openrouter_api_key_here

# --- OPTION C: Ollama (fully local, no API key needed) ---
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1
# LLM_BASE_URL=http://localhost:11434

# --- OPTION D: HuggingFace Inference API (free tier) ---
# LLM_PROVIDER=huggingface
# LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
# LLM_API_KEY=your_hf_token_here

LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1

# ============================================================
# EMBEDDING PROVIDER - Choose one of: local, huggingface, ollama
# ============================================================

# --- OPTION A: Local sentence-transformers (default, no API key) ---
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- OPTION B: HuggingFace Inference API ---
# EMBEDDING_PROVIDER=huggingface
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_API_KEY=your_hf_token_here

# --- OPTION C: Ollama local embeddings ---
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIM=768

# --- Rate limiting ---
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60

# --- Timeouts ---
INGESTION_TIMEOUT=300
QUERY_TIMEOUT=60
